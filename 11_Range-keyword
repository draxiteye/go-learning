package main

import "fmt"

func main() {
	//range is used to iterate over data structures
	nums := []int{4, 5, 2}

	//this is using normal for loops 
	/*for i := 0; i < len(nums); i++ {
		fmt.Println(nums[i])
	}
	*/

	//using range keyword 
	for _, num := range nums {
		fmt.Println(num)
	}

	m := make(map[string]string)
	m["class"] = "dev"
	m["student"] = "draxiteye"

	for _, value := range m {
		fmt.Println(value)
	}

	//for getting unicode values 
	for i, c := range m["class"] {
		fmt.Println(i, c)
	}
	//if you want to get the rune of the word 
	//pass c as string(c) in print
}
